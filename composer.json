{
  "name": "mhshagor/system-core",
  "description": "Simple global middleware for Laravel",
  "version": "1.2",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "middleware"
  ],
  "authors": [
    {
      "name": "M. H Shagor",
      "email": "srq001100@gmail.com"
    }
  ],
  "require": {
    "php": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "SystemCore\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "SystemCore\\Providers\\SystemCoreServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
