{
    "name": "vendor/system-core",
    "description": "Simple global middleware for Laravel",
    "type": "library",
    "license": "proprietary",
    "keywords": ["laravel", "middleware"],
    "authors": [
        {
            "name": "System Core Team",
            "email": "core@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SystemCore\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SystemCore\\Providers\\SystemCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
